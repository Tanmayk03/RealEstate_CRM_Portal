# Optional. If unset during `npm run dev`, requests use the Vite proxy to 127.0.0.1:8088 (recommended on Windows).
# Set only if you call the API directly (then prefer 127.0.0.1, not "localhost"):
# VITE_API_URL=http://127.0.0.1:8088

# If the API is not on 8088, set both (dev proxy + direct URL if you use VITE_API_URL):
# VITE_PROXY_TARGET=http://127.0.0.1:9000
# VITE_API_URL=http://127.0.0.1:9000
